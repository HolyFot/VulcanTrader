{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "max_open_trades": 3,
    "stake_currency": "USDC",
    "max_stake_amount": 50000,
    "stake_amount": 10000,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 12000,
    "cancel_open_orders_on_exit": true,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "liquidation_buffer": 0.05,
    "leverage": 5,
    "unfilledtimeout": {
        "entry": 25,
        "exit": 25,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "other",
        "use_order_book": false,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "other",
        "use_order_book": false,
        "order_book_top": 1
    },
    "exchange": {
        "name": "hyperliquid",
        "key": "",
        "secret": "",
        "ccxt_async_config": {},
        "use_public_trades": false,
        "pair_whitelist": [],
        "pair_blacklist": [
            "SOL-PERP",
            "ETH-PERP",
            "BTC-PERP",
            "HYPE-PERP",
            "WIF-PERP",
            "LINK-PERP",
            "PENGU-PERP",
            "SUI-PERP",
            "JUP-PERP",
            "JTO-PERP",
            "XRP-PERP",
            "XPL-PERP",
            "DRIFT-PERP",
            "FARCOIN-PERP",
            "AVAX-PERP",
            "MNT-PERP",
            "INJ-PERP",
            "1MONK-PERP",
            "ASTER-PERP",
            "PAXG-PERP",
            "ZEC-PERP",
            "MET-PERP",
            "LTC-PERP",
            "BNB-PERP"
        ],
        "ccxt_config": {
            "enableRateLimit": true,
            "rateLimit": 50
        }
    },
    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 30,
            "sort_key": "quoteVolume",
            "min_value": 5000000,
            "refresh_period": 3600
        },
        {
            "method": "AgeFilter",
            "min_days_listed": 14
        },
        {
            "method": "PrecisionFilter"
        },
        {
            "method": "RangeStabilityFilter",
            "lookback_days": 3,
            "min_rate_of_change": 0.03,
            "refresh_period": 1440
        }
    ],
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "discord": {
        "enabled": true,
        "webhook_url": "",
        "bot_token": "",
        "allowed_user_ids": []
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "info",
        "enable_openapi": true,
        "jwt_secret_key": "somethingRandomSomethingRandom123",
        "CORS_origins": [],
        "username": "test",
        "password": "test"
    },
    "db_url": "json:user_data/accounts/trades-Drift.json",
    "bot_name": "Drift",
    "initial_state": "running",
    "force_entry_enable": false,
    "hyperopt_ignore_missing_space": true,
    "internals": {
        "process_throttle_secs": 5
    }
}
